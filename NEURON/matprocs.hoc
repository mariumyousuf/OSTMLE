proc readmat() { 
  if (numarg() < 1) {
    printf("Usage: readmat(filename)\n")
    return
  }
  strdef fname
  fname = $s1   // filename passed as string
  f1 = new File()
  f1.ropen(fname)

  numrows = f1.scanvar()
  numcols = f1.scanvar()

  mat = new Matrix(numrows, numcols)
  for i=0, numrows-1 {
    for k=0, numcols-1 {
      mat.x[i][k] = f1.scanvar()
    }
  }
  f1.close()
}

proc saveSpikeData() {
  if (numarg() < 2) {
    printf("Usage: saveSpikeData(filename, Nsamples)\n")
    return
  }

  strdef fname
  strdef basefolder
  fname = $s1   // filename from Python
  basefolder = $s2
  N = $3        // number of spike samples
  numSamples = $4

  print N
  print fname
  readmat(fname)   // now works with any filename
  updateweights()
  print "done"

  for idx=0,numSamples-1 {
      strdef outname
      sprint(outname, "%s/rasterplot_N%d_%d.txt", basefolder, N, idx)
      go()
      SaveRaster(outname)
  }
}
